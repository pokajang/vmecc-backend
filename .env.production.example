APP_NAME=VMECC
APP_ENV=production
APP_KEY=base64:REPLACE_WITH_SERVER_APP_KEY
APP_DEBUG=false
APP_URL=https://vmecc-api.amiosh.com
APP_FRONTEND_URL=https://vmecc.amiosh.com

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=REPLACE_WITH_PRODUCTION_DATABASE
DB_USERNAME=REPLACE_WITH_PRODUCTION_DATABASE_USER
DB_PASSWORD=REPLACE_WITH_PRODUCTION_DATABASE_PASSWORD

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
PUBLIC_UPLOADS_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.amiosh.com
SESSION_SECURE_COOKIE=true
SANCTUM_STATEFUL_DOMAINS=vmecc.amiosh.com
CORS_ALLOWED_ORIGINS=https://vmecc.amiosh.com

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=REPLACE_WITH_SMTP_HOST
MAIL_PORT=587
MAIL_USERNAME=REPLACE_WITH_SMTP_USERNAME
MAIL_PASSWORD=REPLACE_WITH_SMTP_PASSWORD
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@amiosh.com
MAIL_FROM_NAME="${APP_NAME}"
LEAVE_EMAIL_ENABLED=false
WORKFLOW_EMAIL_ENABLED=false
WORKFLOW_EMAIL_MODULE_LEAVE=false
WORKFLOW_EMAIL_MODULE_OVERTIME=false
WORKFLOW_EMAIL_MODULE_SALARY=false
WORKFLOW_EMAIL_MODULE_EXPENSE=false
WORKFLOW_EMAIL_MODULE_EXCEPTIONAL=false
WORKFLOW_EMAIL_MODULE_SALARY_ASSIGNMENT=false
WORKFLOW_EMAIL_MODULE_TEAM=false
WORKFLOW_EMAIL_MODULE_ROSTER=false

FEATURE_OT_PAYROLL_READS_PRIMARY=true
FEATURE_OT_PAYROLL_WRITES_PRIMARY=true
FEATURE_OT_PAYROLL_LOCAL_FALLBACK_ENABLED=false
FEATURE_OT_PAYROLL_MIGRATION_ENABLED=false
FEATURE_HOLIDAY_GUIDANCE_LEAVE_ENABLED=true
FEATURE_HOLIDAY_GUIDANCE_OVERTIME_ENABLED=true
FEATURE_HOLIDAY_GUIDANCE_STAFF_VISIBILITY_ENABLED=false
FEATURE_HOLIDAY_GUIDANCE_COHORT_USER_IDS=
FEATURE_HOLIDAY_GUIDANCE_COHORT_EMAILS=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
