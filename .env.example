# Local development template only.
# For production, start from .env.production.example and keep real secrets server-side.
APP_NAME=VMECC
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=vmecc
DB_USERNAME=postgres
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
PUBLIC_UPLOADS_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=720
SESSION_REMEMBER_DAYS=30

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"
LEAVE_EMAIL_ENABLED=false
WORKFLOW_EMAIL_ENABLED=false
WORKFLOW_EMAIL_MODULE_LEAVE=false
WORKFLOW_EMAIL_MODULE_OVERTIME=false
WORKFLOW_EMAIL_MODULE_SALARY=false
WORKFLOW_EMAIL_MODULE_EXPENSE=false
WORKFLOW_EMAIL_MODULE_EXCEPTIONAL=false
WORKFLOW_EMAIL_MODULE_SALARY_ASSIGNMENT=false
FEATURE_OT_PAYROLL_READS_PRIMARY=true
FEATURE_OT_PAYROLL_WRITES_PRIMARY=true
FEATURE_OT_PAYROLL_LOCAL_FALLBACK_ENABLED=false
FEATURE_OT_PAYROLL_MIGRATION_ENABLED=false
FEATURE_HOLIDAY_GUIDANCE_LEAVE_ENABLED=true
FEATURE_HOLIDAY_GUIDANCE_OVERTIME_ENABLED=true
FEATURE_HOLIDAY_GUIDANCE_STAFF_VISIBILITY_ENABLED=false
FEATURE_HOLIDAY_GUIDANCE_COHORT_USER_IDS=
FEATURE_HOLIDAY_GUIDANCE_COHORT_EMAILS=
MODULE_ACTIVATION_FORCE_ALL_ENABLED=false

AI_HELPER_ENABLED=true
AI_HELPER_RATE_LIMIT_PER_MINUTE=12
AI_HELPER_TIMEOUT_SECONDS=60
AI_HELPER_MAX_MESSAGE_LENGTH=2000
AI_HELPER_HISTORY_TURNS=12
AI_HELPER_KNOWLEDGE_UPLOAD_MAX_KB=10240
AI_HELPER_MARKDOWN_UPLOAD_MAX_KB=1024
AI_HELPER_KNOWLEDGE_EXTRACT_MAX_CHARACTERS=30000
AI_HELPER_KNOWLEDGE_CHUNK_CHARACTERS=1000
AI_HELPER_KNOWLEDGE_MAX_CHUNKS_PER_ENTRY=40
AI_HELPER_KNOWLEDGE_RETRIEVAL_LIMIT=6
AI_HELPER_KNOWLEDGE_REQUIRE_SHARED_REVIEW=true
AI_HELPER_KNOWLEDGE_MAX_ACTIVE_UPLOADS_PER_USER=100
AI_HELPER_KNOWLEDGE_MAX_UPLOAD_BYTES_PER_USER=2147483648
AI_HELPER_KNOWLEDGE_MAX_TOTAL_UPLOAD_BYTES=21474836480
AI_HELPER_KNOWLEDGE_DELETED_RETENTION_DAYS=30
AI_HELPER_KNOWLEDGE_FAILED_RETENTION_DAYS=14
AI_HELPER_HISTORY_MAX_CHARACTERS=12000
OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_HELPER_MODEL=gpt-5.4-mini
OPENAI_BASE_URL=https://api.openai.com/v1

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
